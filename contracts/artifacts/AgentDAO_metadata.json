		"devdoc": {
			"details": "A simple DAO designed to govern the AgentAuditLogger protocol.  Allows DAO members to vote on challenged agent decisions and resolve them transparently.",
			"kind": "dev",
			"methods": {
				"castVote(uint256,bool)": {
					"details": "DAO members cast their vote.",
					"params": {
						"_decisionId": "The decision ID being voted on.",
						"_voteUpheld": "True means \"I agree with the Challenger. Agent is wrong.\"                    False means \"I disagree with Challenger. Agent is right.\""
					}
				},
				"challengeAndInitiateVote(uint256)": {
					"details": "Allows a DAO member to directly challenge a decision and immediately start the voting process."
				},
				"constructor": {
					"details": "Initialize DAO with the logger and add deployer as first member",
					"params": {
						"_loggerAddress": "Address of deployed AgentAuditLogger"
					}
				},
				"executeResolution(uint256)": {
					"details": "Execute the result of the vote and call resolveDispute on the Logger. Can be called by anyone once the voting period has ended."
				},
				"initiateDisputeVote(uint256)": {
					"details": "Start a vote to resolve a challenged decision. Starts a 3-day voting window."
				}
			},
