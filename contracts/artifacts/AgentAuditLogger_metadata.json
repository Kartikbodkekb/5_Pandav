		"devdoc": {
			"details": "Protocol for transparent logging, explainability, and verification of decisions made by autonomous agents.",
			"kind": "dev",
			"methods": {
				"challengeDecision(uint256)": {
					"details": "Allows any user or governing body to challenge an agent's decision.",
					"params": {
						"_id": "The ID of the decision to challenge."
					}
				},
				"constructor": {
					"details": "Sets the deployer as the initial governance/DAO role."
				},
				"getDecision(uint256)": {
					"details": "Retrieves the full details of a decision.",
					"params": {
						"_id": "The ID of the decision."
					},
					"returns": {
						"_0": "The Decision struct containing all properties."
					}
				},
				"logDecision(string,string,uint256,string)": {
					"details": "Log a decision made by an autonomous agent.",
					"params": {
						"_action": "The action taken.",
						"_amount": "Any numeric value or token amount associated with the decision.",
						"_reason": "Human-readable explanation for the decision."
					},
					"returns": {
						"_0": "id The unique ID of the logged decision."
					}
				},
				"resolveDispute(uint256,bool)": {
					"details": "Resolves a challenged decision. Only callable by the governance role.",
					"params": {
						"_id": "The ID of the decision.",
						"_upheld": "True if the challenge was upheld (agent was wrong/overridden), false if rejected (agent was right)."
					}
				},
				"transferGovernance(address)": {
					"details": "Allows updating the governance role (e.g., transferring control to a DAO).",
					"params": {
						"_newGovernance": "The address of the new governance contract/wallet."
					}
				}
			},
